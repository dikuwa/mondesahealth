generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String                     @id @default(cuid())
  name                 String
  email                String                     @unique
  passwordHash         String
  role                 String                     @default("RECEPTIONIST")
  permissions          String                     @default("[]")
  avatarData           String?
  active               Boolean                    @default(true)
  mustChangePassword   Boolean                    @default(false)
  sessionVersion       Int                        @default(0)
  updatedAt            DateTime                   @default(now()) @updatedAt
  createdAt            DateTime                   @default(now())
  appointments         Appointment[]              @relation("CreatedBy")
  payments             Payment[]
  logs                 ActivityLog[]
  appointmentResponses AppointmentChangeRequest[] @relation("ChangeResponder")
  icd10Imports         Icd10Import[]              @relation("Icd10Importer")
  consentsCaptured     MedicalAidConsent[]        @relation("ConsentCapturer")
  claimsCreated        Claim[]                    @relation("ClaimCreator")
  claimEvents          ClaimStatusEvent[]
  batchesSubmitted     ClaimBatch[]               @relation("BatchSubmitter")
  claimAttachments     ClaimAttachment[]
  notifications        Notification[]
  invoicesVoided       Invoice[]                  @relation("InvoiceVoider")
  reminderActions      AppointmentReminder[]      @relation("ReminderActor")
  reviewedIntakes      PatientIntake[]            @relation("IntakeReviewer")
  clinicalAiDrafts     ClinicalAiDraft[]
  sickNotesAsDoctor    SickNote[]                 @relation("SickNoteDoctor")
  sickNotesCreated     SickNote[]                 @relation("SickNoteCreator")
  sickNotesUpdated     SickNote[]                 @relation("SickNoteUpdater")
  practiceId           String                     @default("mondesa-health")
  platformRole         String?
  practice             Practice                   @relation(fields: [practiceId], references: [id])
  practiceMemberships  PracticeUser[]
  encounters           ClinicalEncounter[]        @relation("EncounterClinician")
  encountersCreated    ClinicalEncounter[]        @relation("EncounterCreator")
  encountersUpdated    ClinicalEncounter[]        @relation("EncounterUpdater")
  encounterAmendments  EncounterAmendment[]

  @@index([practiceId, active])
}

model Practice {
  id                    String                 @id @default(cuid())
  slug                  String                 @unique
  name                  String
  type                  String                 @default("GENERAL_PRACTICE")
  ownerName             String?
  registrationNumber    String?
  licenceInformation    String?
  email                 String?
  phone                 String?
  whatsapp              String?
  address               String?
  town                  String?
  region                String?
  logoData              String?
  description           String?
  status                String                 @default("DRAFT")
  subscriptionStatus    String                 @default("ACTIVE")
  publicVisible         Boolean                @default(false)
  activatedAt           DateTime?
  suspensionReason      String?
  timezone              String                 @default("Africa/Windhoek")
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  users                 User[]
  memberships           PracticeUser[]
  patients              Patient[]
  appointments          Appointment[]
  encounters            ClinicalEncounter[]
  services              DepartmentService[]
  providers             Provider[]
  availabilityRules     AvailabilityRule[]
  blockedTimes          BlockedTime[]
  setting               PracticeSetting?
  content               PracticeContent?
  emergencyContacts     EmergencyContact[]
  subscriptions         PracticeSubscription[]
  invitations           UserInvitation[]
  patientSharesSent     PatientShareConsent[]  @relation("PatientShareSource")
  patientSharesReceived PatientShareConsent[]  @relation("PatientShareDestination")

  @@index([status, publicVisible])
  @@index([type, status])
}

model PracticeUser {
  id          String   @id @default(cuid())
  practiceId  String
  userId      String
  role        String
  permissions String   @default("[]")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  practice    Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([practiceId, userId])
  @@index([userId, active])
}

model Notification {
  id         String    @id @default(cuid())
  userId     String
  type       String
  title      String
  message    String
  href       String
  readAt     DateTime?
  createdAt  DateTime  @default(now())
  practiceId String    @default("mondesa-health")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

model Patient {
  id                    String                @id @default(cuid())
  patientNumber         String
  fullName              String
  surname               String                @default("")
  initials              String                @default("")
  dateOfBirth           DateTime?
  gender                String?
  identityNumber        String?
  nationality           String?
  phone                 String
  whatsapp              String?
  email                 String?
  address               String?
  preferredMethod       String                @default("WHATSAPP")
  emergencyName         String?
  emergencyPhone        String?
  emergencyRelation     String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  archivedAt            DateTime?
  practiceId            String                @default("mondesa-health")
  firstName             String?
  middleName            String?
  lastName              String?
  sex                   String?
  identificationType    String?
  passportNumber        String?
  normalizedPhone       String?
  town                  String?
  region                String?
  knownAllergies        String?
  chronicConditions     String?
  currentMedication     String?
  previousProcedures    String?
  medicalAlerts         String?
  medicalHistorySummary String?
  status                String                @default("ACTIVE")
  createdById           String?
  updatedById           String?
  practice              Practice              @relation(fields: [practiceId], references: [id])
  appointments          Appointment[]
  memberships           PatientMedicalAid[]
  claims                Claim[]
  invoices              Invoice[]
  payments              Payment[]
  consents              MedicalAidConsent[]
  sickNotes             SickNote[]
  encounters            ClinicalEncounter[]
  allergies             PatientAllergy[]
  conditions            PatientCondition[]
  medications           PatientMedication[]
  sharingConsents       PatientShareConsent[]

  @@unique([practiceId, patientNumber])
  @@index([practiceId, archivedAt, fullName])
  @@index([practiceId, normalizedPhone])
  @@index([practiceId, identityNumber])
}

model PatientShareConsent {
  id                    String    @id @default(cuid())
  patientId             String
  sourcePracticeId      String
  destinationPracticeId String
  scopes                String
  status                String    @default("ACTIVE")
  patientOrGuardianName String
  relationshipToPatient String?
  consentMethod         String
  consentStatement      String
  grantedById           String
  grantedAt             DateTime  @default(now())
  expiresAt             DateTime
  revokedAt             DateTime?
  revokedById           String?
  revocationReason      String?
  lastViewedAt          DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  patient               Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  sourcePractice        Practice  @relation("PatientShareSource", fields: [sourcePracticeId], references: [id], onDelete: Cascade)
  destinationPractice   Practice  @relation("PatientShareDestination", fields: [destinationPracticeId], references: [id], onDelete: Cascade)

  @@index([sourcePracticeId, patientId, status, expiresAt])
  @@index([destinationPracticeId, status, expiresAt])
}

model MedicalAid {
  id                        String              @id @default(cuid())
  name                      String              @unique
  normalizedName            String              @unique
  abbreviation              String?
  administrator             String?
  claimsEmail               String?
  supportEmail              String?
  phone                     String?
  portalUrl                 String?
  submissionInstructions    String?
  postalAddress             String?
  physicalAddress           String?
  acceptedSubmissionMethods String              @default("[]")
  coverSheetRequired        Boolean             @default(false)
  serviceDateRangeRequired  Boolean             @default(false)
  active                    Boolean             @default(true)
  public                    Boolean             @default(true)
  sortOrder                 Int                 @default(0)
  memberships               PatientMedicalAid[]
  claims                    Claim[]
  batches                   ClaimBatch[]
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @default(now()) @updatedAt
}

model PatientMedicalAid {
  id                     String              @id @default(cuid())
  patientId              String
  medicalAidId           String?
  customFundName         String?
  membershipNumber       String?
  plan                   String?
  principalName          String?
  principalId            String?
  dependantCode          String?
  relationship           String?
  beneficiarySuffix      String?
  effectiveDate          DateTime?
  expiryDate             DateTime?
  preAuthorisationNumber String?
  directBillingEnabled   Boolean             @default(true)
  reimbursementOnly      Boolean             @default(false)
  notes                  String?
  current                Boolean             @default(true)
  verified               Boolean             @default(false)
  patient                Patient             @relation(fields: [patientId], references: [id])
  medicalAid             MedicalAid?         @relation(fields: [medicalAidId], references: [id])
  consents               MedicalAidConsent[]
  claims                 Claim[]
  attachments            ClaimAttachment[]
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @default(now()) @updatedAt
  practiceId             String              @default("mondesa-health")

  @@index([patientId, current])
}

model Appointment {
  id               String                     @id @default(cuid())
  reference        String                     @unique
  patientId        String
  startAt          DateTime?
  endAt            DateTime?
  preferredDate    DateTime?
  preferredPeriod  String?
  preferredTime    String?
  status           String                     @default("NEW_REQUEST")
  bookingMode      String                     @default("AVAILABLE_TIME")
  source           String                     @default("PUBLIC")
  reason           String
  notes            String?
  internalNote     String?
  originalStartAt  DateTime?
  rescheduleReason String?
  contacted        Boolean                    @default(false)
  createdById      String?
  patient          Patient                    @relation(fields: [patientId], references: [id])
  createdBy        User?                      @relation("CreatedBy", fields: [createdById], references: [id])
  claim            Claim?
  invoice          Invoice?
  secureLinks      SecureLink[]
  changeRequests   AppointmentChangeRequest[]
  reminders        AppointmentReminder[]
  departmentId     String?
  serviceId        String?
  providerId       String?
  department       Department?                @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  service          DepartmentService?         @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  provider         Provider?                  @relation(fields: [providerId], references: [id], onDelete: SetNull)
  patientIntake    PatientIntake?
  sickNotes        SickNote[]
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  practiceId       String                     @default("mondesa-health")
  practice         Practice                   @relation(fields: [practiceId], references: [id])
  encounters       ClinicalEncounter[]

  @@unique([practiceId, startAt])
  @@index([status, startAt])
  @@index([practiceId, startAt])
  @@index([practiceId, status, startAt])
}

model AvailabilityRule {
  id              String   @id @default(cuid())
  weekday         Int
  practiceId      String   @default("mondesa-health")
  active          Boolean  @default(true)
  openTime        String
  closeTime       String
  lunchStart      String?
  lunchEnd        String?
  durationMinutes Int      @default(30)
  bufferMinutes   Int      @default(0)
  maximumPerDay   Int      @default(16)
  practice        Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@unique([practiceId, weekday])
}

model BlockedTime {
  id         String   @id @default(cuid())
  startAt    DateTime
  endAt      DateTime
  reason     String?
  practiceId String   @default("mondesa-health")
  providerId String?
  practice   Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([practiceId, startAt, endAt])
}

model PracticeSetting {
  id                 String   @id @default("practice")
  practiceName       String   @default("Mondesa Health")
  doctorName         String   @default("Dr Helena Ndeitunga")
  practiceNumber     String   @default("Pending configuration")
  registrationNumber String   @default("Pending configuration")
  phone              String   @default("+264 81 000 0000")
  whatsapp           String   @default("+264 81 000 0000")
  email              String   @default("hello@mondesahealth.na")
  address            String   @default("Mondesa, Swakopmund, Namibia")
  bookingMode        String   @default("AVAILABLE_TIME")
  minNoticeHours     Int      @default(2)
  maxAdvanceDays     Int      @default(60)
  cancellationPolicy String   @default("Please give at least 4 hours' notice when possible.")
  currency           String   @default("NAD")
  signatureName      String   @default("Dr Helena Ndeitunga")
  signatureTitle     String   @default("Medical Practitioner")
  vatEnabled         Boolean  @default(false)
  tagline            String   @default("Your Health. Your Choice. Your Community.")
  publicDescription  String   @default("Mondesa Health Polyclinic brings multiple healthcare disciplines together in one trusted community healthcare destination.")
  locationNote       String   @default("")
  mapsUrl            String   @default("")
  mapLatitude        Float?
  mapLongitude       Float?
  publicHours        String?
  showEmail          Boolean  @default(false)
  showWhatsapp       Boolean  @default(false)
  claimContactName   String   @default("")
  claimPhone         String   @default("")
  claimEmail         String   @default("")
  claimPostalAddress String   @default("")
  consentWording     String   @default("I understand that diagnosis information may be represented using ICD-10 codes and disclosed to the selected medical-aid fund or its administrator for the purpose of processing and assessing my medical-aid claim.")
  reminderEnabled    Boolean  @default(true)
  reminderLeadHours  Int      @default(24)
  aiIntakeEnabled    Boolean  @default(false)
  aiImageEnabled     Boolean  @default(false)
  practiceId         String   @unique @default("mondesa-health")
  practice           Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
}

model EmergencyContact {
  id          String   @id @default(cuid())
  label       String
  phone       String
  description String?
  region      String?
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  primary     Boolean  @default(false)
  practiceId  String   @default("mondesa-health")
  practice    Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([practiceId, active, primary, sortOrder])
}

model PracticeContent {
  id         String   @id @default(cuid())
  practiceId String   @unique @default("mondesa-health")
  content    Json
  practice   Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
}

model Department {
  id             String              @id @default(cuid())
  slug           String              @unique
  name           String
  categoryLabel  String
  summary        String
  description    String
  status         String              @default("COMING_SOON")
  public         Boolean             @default(true)
  bookingEnabled Boolean             @default(false)
  sortOrder      Int                 @default(0)
  services       DepartmentService[]
  providers      Provider[]
  appointments   Appointment[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([public, sortOrder])
  @@index([status])
}

model DepartmentService {
  id              String        @id @default(cuid())
  departmentId    String
  name            String
  description     String?
  public          Boolean       @default(true)
  sortOrder       Int           @default(0)
  aiIntakeEnabled Boolean?
  practiceId      String        @default("mondesa-health")
  durationMinutes Int           @default(30)
  active          Boolean       @default(true)
  practice        Practice      @relation(fields: [practiceId], references: [id])
  department      Department    @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  appointments    Appointment[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([practiceId, departmentId, name])
  @@index([departmentId, public, sortOrder])
  @@index([practiceId, active, public])
}

model Provider {
  id              String                 @id @default(cuid())
  departmentId    String
  displayName     String
  practiceName    String?
  biography       String?
  phone           String?
  email           String?
  operatingHours  String?
  public          Boolean                @default(false)
  sortOrder       Int                    @default(0)
  aiIntakeEnabled Boolean?
  practiceId      String                 @default("mondesa-health")
  userId          String?
  practice        Practice               @relation(fields: [practiceId], references: [id])
  department      Department             @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  appointments    Appointment[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  availability    ProviderAvailability[]

  @@index([departmentId, public, sortOrder])
  @@index([practiceId, public])
}

model Claim {
  id                       String             @id @default(cuid())
  claimNumber              String             @unique
  patientId                String
  appointmentId            String?            @unique
  patientMedicalAidId      String?
  medicalAidFundId         String?
  createdByUserId          String?
  originalClaimId          String?
  status                   String             @default("DRAFT")
  claimType                String             @default("DIRECT_MEDICAL_AID")
  submissionType           String             @default("FIRST_SUBMISSION")
  isResubmission           Boolean            @default(false)
  serviceDateFrom          DateTime?
  serviceDateTo            DateTime?
  consultationDate         DateTime
  practitioner             String
  practiceNumber           String
  medicalAidSnapshot       String?
  membershipSnapshot       String?
  principalSnapshot        String?
  dependantSnapshot        String?
  planSnapshot             String?
  primaryDiagnosis         String?
  primaryIcd10             String?
  amountSubmitted          Float              @default(0)
  amountApproved           Float              @default(0)
  amountReceived           Float              @default(0)
  patientShortfall         Float              @default(0)
  patientSnapshot          String?
  membershipDetailSnapshot String?
  providerSnapshot         String?
  practiceSnapshot         String?
  consentSnapshot          String?
  validationState          String?
  internalNotes            String?
  submittedAt              DateTime?
  acknowledgedAt           DateTime?
  patient                  Patient            @relation(fields: [patientId], references: [id])
  appointment              Appointment?       @relation(fields: [appointmentId], references: [id])
  patientMedicalAid        PatientMedicalAid? @relation(fields: [patientMedicalAidId], references: [id])
  medicalAidFund           MedicalAid?        @relation(fields: [medicalAidFundId], references: [id])
  createdBy                User?              @relation("ClaimCreator", fields: [createdByUserId], references: [id])
  originalClaim            Claim?             @relation("ClaimResubmissions", fields: [originalClaimId], references: [id])
  resubmissions            Claim[]            @relation("ClaimResubmissions")
  lines                    ClaimLine[]
  batches                  ClaimBatchItem[]
  payments                 Payment[]
  statusEvents             ClaimStatusEvent[]
  attachments              ClaimAttachment[]
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  practiceId               String             @default("mondesa-health")

  @@index([status, updatedAt])
  @@index([patientId, serviceDateFrom])
  @@index([medicalAidFundId, status])
  @@index([practiceId, status, updatedAt])
}

model ClaimLine {
  id                           String                   @id @default(cuid())
  claimId                      String
  serviceDate                  DateTime?
  procedureItemId              String?
  procedureCodeSnapshot        String?
  procedureDescriptionSnapshot String?
  tariffCode                   String?
  description                  String
  icd10                        String?
  quantity                     Float                    @default(1)
  rate                         Float
  claimed                      Float
  approved                     Float                    @default(0)
  rejected                     Float                    @default(0)
  patientAmount                Float                    @default(0)
  modifier                     String?
  nappiCode                    String?
  medicationDescription        String?
  referralDiagnosis            String?
  preAuthorisationNumber       String?
  clinicalClaimNote            String?
  sortOrder                    Int                      @default(0)
  claim                        Claim                    @relation(fields: [claimId], references: [id], onDelete: Cascade)
  procedureItem                MedicalAidProcedureItem? @relation(fields: [procedureItemId], references: [id])
  diagnosisCodes               ClaimLineIcd10Code[]

  @@index([claimId, sortOrder])
}

model ClaimBatch {
  id                  String            @id @default(cuid())
  reference           String            @unique
  medicalAidName      String
  medicalAidFundId    String?
  submissionType      String            @default("FIRST_SUBMISSION")
  datePrepared        DateTime          @default(now())
  serviceDateFrom     DateTime?
  serviceDateTo       DateTime?
  totalClaims         Int               @default(0)
  periodStart         DateTime
  periodEnd           DateTime
  totalAmount         Float
  status              String            @default("DRAFT")
  submissionMethod    String?
  submittedAt         DateTime?
  submissionReference String?
  submittedByUserId   String?
  acknowledgedAt      DateTime?
  notes               String?
  medicalAidFund      MedicalAid?       @relation(fields: [medicalAidFundId], references: [id])
  submittedBy         User?             @relation("BatchSubmitter", fields: [submittedByUserId], references: [id])
  items               ClaimBatchItem[]
  attachments         ClaimAttachment[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @default(now()) @updatedAt
  practiceId          String            @default("mondesa-health")

  @@index([medicalAidFundId, status])
  @@index([practiceId, status])
}

model ClaimBatchItem {
  batchId String
  claimId String
  batch   ClaimBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  claim   Claim      @relation(fields: [claimId], references: [id])

  @@id([batchId, claimId])
}

model MedicalAidConsent {
  id                    String             @id @default(cuid())
  patientId             String
  patientMedicalAidId   String?
  consentStatus         String             @default("NOT_CAPTURED")
  consentDate           DateTime           @default(now())
  patientOrGuardianName String
  relationshipToPatient String?
  capturedByUserId      String
  signatureData         String?
  notes                 String?
  practiceId            String             @default("mondesa-health")
  patient               Patient            @relation(fields: [patientId], references: [id])
  patientMedicalAid     PatientMedicalAid? @relation(fields: [patientMedicalAidId], references: [id])
  capturedBy            User               @relation("ConsentCapturer", fields: [capturedByUserId], references: [id])
  createdAt             DateTime           @default(now())

  @@index([practiceId, patientId, consentDate])
}

model Icd10Import {
  id               String      @id @default(cuid())
  versionName      String      @unique
  sourceFilename   String
  importedAt       DateTime    @default(now())
  importedByUserId String?
  totalRows        Int         @default(0)
  importedRows     Int         @default(0)
  skippedRows      Int         @default(0)
  invalidRows      Int         @default(0)
  active           Boolean     @default(false)
  notes            String?
  importedBy       User?       @relation("Icd10Importer", fields: [importedByUserId], references: [id])
  codes            Icd10Code[]

  @@index([active, importedAt])
}

model Icd10Code {
  id                        String               @id @default(cuid())
  importId                  String
  code                      String
  description               String
  threeCharacterCode        String?
  threeCharacterDescription String?
  chapter                   String?
  chapterDescription        String?
  groupCode                 String?
  groupDescription          String?
  validForClinicalUse       Boolean              @default(false)
  validForPrimary           Boolean              @default(false)
  validAsterisk             Boolean              @default(false)
  validDagger               Boolean              @default(false)
  validSequelae             Boolean              @default(false)
  ageRange                  String?
  minimumAge                Int?
  maximumAge                Int?
  genderRestriction         String?
  status                    String?
  startDate                 DateTime?
  endDate                   DateTime?
  comment                   String?
  import                    Icd10Import          @relation(fields: [importId], references: [id], onDelete: Cascade)
  claimLines                ClaimLineIcd10Code[]
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt

  @@unique([importId, code])
  @@index([code])
  @@index([description])
  @@index([importId, validForClinicalUse, validForPrimary])
}

model MedicalAidProcedureItem {
  id                       String      @id @default(cuid())
  code                     String      @unique
  name                     String
  description              String?
  category                 String?
  defaultAmount            Float       @default(0)
  requiresNappiCode        Boolean     @default(false)
  requiresPreAuthorisation Boolean     @default(false)
  active                   Boolean     @default(true)
  claimLines               ClaimLine[]
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt
}

model ClaimLineIcd10Code {
  id                  String     @id @default(cuid())
  claimLineId         String
  icd10CodeId         String?
  codeSnapshot        String
  descriptionSnapshot String
  position            String     @default("SECONDARY")
  isPrimary           Boolean    @default(false)
  sortOrder           Int        @default(0)
  claimLine           ClaimLine  @relation(fields: [claimLineId], references: [id], onDelete: Cascade)
  icd10Code           Icd10Code? @relation(fields: [icd10CodeId], references: [id])
  createdAt           DateTime   @default(now())

  @@unique([claimLineId, codeSnapshot])
  @@index([claimLineId, isPrimary])
}

model ClaimStatusEvent {
  id                   String   @id @default(cuid())
  claimId              String
  previousStatus       String?
  newStatus            String
  reason               String?
  rejectionCode        String?
  rejectionDescription String?
  changedByUserId      String
  claim                Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)
  changedBy            User     @relation(fields: [changedByUserId], references: [id])
  createdAt            DateTime @default(now())

  @@index([claimId, createdAt])
}

model ClaimAttachment {
  id                  String             @id @default(cuid())
  claimId             String?
  batchId             String?
  patientMedicalAidId String?
  attachmentType      String
  filename            String
  mimeType            String
  fileSize            Int
  data                Bytes
  uploadedByUserId    String
  claim               Claim?             @relation(fields: [claimId], references: [id], onDelete: Cascade)
  batch               ClaimBatch?        @relation(fields: [batchId], references: [id], onDelete: Cascade)
  patientMedicalAid   PatientMedicalAid? @relation(fields: [patientMedicalAidId], references: [id], onDelete: Cascade)
  uploadedBy          User               @relation(fields: [uploadedByUserId], references: [id])
  createdAt           DateTime           @default(now())
  practiceId          String             @default("mondesa-health")

  @@index([claimId, createdAt])
  @@index([batchId, createdAt])
  @@index([practiceId, createdAt])
}

model Invoice {
  id                       String              @id @default(cuid())
  number                   String              @unique
  patientId                String
  appointmentId            String?             @unique
  status                   String              @default("DRAFT")
  responsibility           String              @default("PATIENT_FULL")
  issueDate                DateTime            @default(now())
  dueDate                  DateTime?
  subtotal                 Float
  adjustment               Float               @default(0)
  total                    Float
  patientResponsibility    Float
  medicalAidResponsibility Float               @default(0)
  patientPaid              Float               @default(0)
  medicalAidPaid           Float               @default(0)
  voidedAt                 DateTime?
  voidReason               String?
  voidedByUserId           String?
  patient                  Patient             @relation(fields: [patientId], references: [id])
  appointment              Appointment?        @relation(fields: [appointmentId], references: [id])
  lines                    InvoiceLine[]
  payments                 Payment[]
  documents                GeneratedDocument[]
  voidedBy                 User?               @relation("InvoiceVoider", fields: [voidedByUserId], references: [id])
  createdAt                DateTime            @default(now())
  practiceId               String              @default("mondesa-health")

  @@index([practiceId, status, issueDate])
}

model InvoiceLine {
  id                String  @id @default(cuid())
  invoiceId         String
  description       String
  tariffCode        String?
  quantity          Float   @default(1)
  rate              Float
  total             Float
  patientPortion    Float
  medicalAidPortion Float   @default(0)
  invoice           Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Payment {
  id         String   @id @default(cuid())
  reference  String   @unique
  patientId  String
  invoiceId  String?
  claimId    String?
  userId     String
  amount     Float
  method     String
  payer      String
  paidAt     DateTime @default(now())
  notes      String?
  patient    Patient  @relation(fields: [patientId], references: [id])
  invoice    Invoice? @relation(fields: [invoiceId], references: [id])
  claim      Claim?   @relation(fields: [claimId], references: [id])
  user       User     @relation(fields: [userId], references: [id])
  receipt    Receipt?
  practiceId String   @default("mondesa-health")

  @@index([practiceId, paidAt])
}

model Receipt {
  id        String              @id @default(cuid())
  number    String              @unique
  paymentId String              @unique
  payment   Payment             @relation(fields: [paymentId], references: [id])
  issuedAt  DateTime            @default(now())
  documents GeneratedDocument[]
}

model GeneratedDocument {
  id          String    @id @default(cuid())
  number      String    @unique
  type        String
  status      String    @default("ISSUED")
  invoiceId   String?
  receiptId   String?
  sickNoteId  String?
  secureToken String?   @unique
  expiresAt   DateTime?
  invoice     Invoice?  @relation(fields: [invoiceId], references: [id])
  receipt     Receipt?  @relation(fields: [receiptId], references: [id])
  sickNote    SickNote? @relation(fields: [sickNoteId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  practiceId  String    @default("mondesa-health")

  @@index([sickNoteId, type, status])
}

model SecureLink {
  id            String      @id @default(cuid())
  tokenHash     String      @unique
  appointmentId String
  purpose       String
  expiresAt     DateTime
  usedAt        DateTime?
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  createdAt     DateTime    @default(now())
}

model AppointmentChangeRequest {
  id              String      @id @default(cuid())
  appointmentId   String
  proposedStartAt DateTime
  proposedEndAt   DateTime
  initiatedBy     String
  status          String      @default("PENDING")
  reason          String?
  expiresAt       DateTime
  respondedAt     DateTime?
  respondedById   String?
  appointment     Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  respondedBy     User?       @relation("ChangeResponder", fields: [respondedById], references: [id])
  createdAt       DateTime    @default(now())

  @@index([status, proposedStartAt, expiresAt])
}

model AppointmentReminder {
  id                 String      @id @default(cuid())
  appointmentId      String
  appointmentStartAt DateTime
  status             String      @default("PREPARED")
  actedByUserId      String?
  actedAt            DateTime?
  appointment        Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  actedBy            User?       @relation("ReminderActor", fields: [actedByUserId], references: [id])
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@unique([appointmentId, appointmentStartAt])
  @@index([status, appointmentStartAt])
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  entityType  String
  entityId    String
  summary     String
  beforeJson  String?
  afterJson   String?
  user        User?    @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  practiceId  String   @default("mondesa-health")
  requestInfo String?

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([userId, createdAt])
  @@index([practiceId, createdAt])
}

model SickNote {
  id                  String              @id @default(cuid())
  certificateNumber   String              @unique
  verificationToken   String?             @unique
  patientId           String
  appointmentId       String?
  doctorUserId        String
  purpose             String
  consultationDate    DateTime
  consultationTime    String?
  leaveFrom           DateTime
  leaveTo             DateTime
  returnDate          DateTime
  fitnessStatus       String
  restrictions        String?
  diagnosisDisclosure String              @default("NOT_DISCLOSED")
  diagnosisPlainText  String?
  doctorNotes         String
  certificateWording  String              @default("")
  aiDraftUsed         Boolean             @default(false)
  status              String              @default("DRAFT")
  issuedAt            DateTime?
  revokedAt           DateTime?
  revokedReason       String?
  createdById         String
  updatedById         String
  patient             Patient             @relation(fields: [patientId], references: [id])
  appointment         Appointment?        @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  doctor              User                @relation("SickNoteDoctor", fields: [doctorUserId], references: [id])
  createdBy           User                @relation("SickNoteCreator", fields: [createdById], references: [id])
  updatedBy           User                @relation("SickNoteUpdater", fields: [updatedById], references: [id])
  generatedDocuments  GeneratedDocument[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  practiceId          String              @default("mondesa-health")

  @@index([status, createdAt])
  @@index([patientId, consultationDate])
  @@index([appointmentId])
  @@index([doctorUserId, issuedAt])
  @@index([practiceId, status, createdAt])
}

model PatientIntake {
  id                          String                 @id @default(cuid())
  appointmentId               String                 @unique
  originalReason              String
  approvedSummary             String?
  symptomOnset                String?
  symptomDuration             String?
  symptomLocation             String?
  severity                    Int?
  symptomPattern              String?
  associatedSymptoms          String?
  aggravatingFactors          String?
  relievingFactors            String?
  treatmentsTried             String?
  knownAllergies              String?
  existingConditions          String?
  currentMedication           String?
  structuredAnswers           String                 @default("{}")
  questionsSkipped            String                 @default("[]")
  redFlags                    String                 @default("[]")
  emergencyNoticeShown        Boolean                @default(false)
  emergencyNoticeAcknowledged Boolean                @default(false)
  aiConsent                   Boolean                @default(false)
  imageConsent                Boolean                @default(false)
  consentVersion              String?
  consentAt                   DateTime?
  aiUsed                      Boolean                @default(false)
  imageUsed                   Boolean                @default(false)
  aiProvider                  String?
  aiModel                     String?
  safetyPolicyVersion         String                 @default("2026-07-19")
  summaryGeneratedAt          DateTime?
  patientApprovedAt           DateTime?
  reviewStatus                String                 @default("NOT_REVIEWED")
  clinicianReviewedAt         DateTime?
  clinicianReviewedByUserId   String?
  clinicianCorrections        String?
  appointment                 Appointment            @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  clinicianReviewedBy         User?                  @relation("IntakeReviewer", fields: [clinicianReviewedByUserId], references: [id], onDelete: SetNull)
  messages                    PatientIntakeMessage[]
  images                      PatientIntakeImage[]
  clinicalDrafts              ClinicalAiDraft[]
  createdAt                   DateTime               @default(now())
  updatedAt                   DateTime               @updatedAt
  practiceId                  String                 @default("mondesa-health")

  @@index([reviewStatus, createdAt])
  @@index([practiceId, createdAt])
}

model PatientIntakeMessage {
  id        String        @id @default(cuid())
  intakeId  String
  role      String
  content   String
  skipped   Boolean       @default(false)
  intake    PatientIntake @relation(fields: [intakeId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@index([intakeId, createdAt])
}

model PatientIntakeImage {
  id        String        @id @default(cuid())
  intakeId  String
  filename  String
  mimeType  String
  fileSize  Int
  data      Bytes
  intake    PatientIntake @relation(fields: [intakeId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@index([intakeId, createdAt])
}

model ClinicalAiDraft {
  id          String        @id @default(cuid())
  intakeId    String
  userId      String
  requestType String
  sourceUsed  String
  content     String
  limitations String?
  status      String        @default("GENERATED")
  intake      PatientIntake @relation(fields: [intakeId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([intakeId, createdAt])
  @@index([userId, createdAt])
}

model PatientAllergy {
  id          String   @id @default(cuid())
  practiceId  String
  patientId   String
  substance   String
  reaction    String?
  severity    String?
  status      String   @default("ACTIVE")
  source      String   @default("CLINICIAN")
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([practiceId, patientId, status])
}

model PatientCondition {
  id          String    @id @default(cuid())
  practiceId  String
  patientId   String
  name        String
  icd10Code   String?
  status      String    @default("ACTIVE")
  onsetDate   DateTime?
  resolvedAt  DateTime?
  source      String    @default("CLINICIAN")
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  patient     Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([practiceId, patientId, status])
}

model PatientMedication {
  id           String    @id @default(cuid())
  practiceId   String
  patientId    String
  name         String
  dose         String?
  frequency    String?
  instructions String?
  status       String    @default("ACTIVE")
  startedAt    DateTime?
  stoppedAt    DateTime?
  source       String    @default("CLINICIAN")
  createdById  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  patient      Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([practiceId, patientId, status])
}

model ClinicalEncounter {
  id                     String                @id @default(cuid())
  practiceId             String
  patientId              String
  appointmentId          String?
  clinicianId            String
  serviceId              String?
  startedAt              DateTime              @default(now())
  presentingComplaint    String?
  patientReportedHistory String?
  aiBookingSummary       String?
  historyPresentIllness  String?
  relevantHistory        String?
  allergiesReviewed      Boolean               @default(false)
  medicationReviewed     Boolean               @default(false)
  vitalSigns             Json?
  examinationFindings    String?
  clinicalObservations   String?
  assessment             String?
  provisionalDiagnosis   String?
  confirmedDiagnosis     String?
  treatmentProvided      String?
  medicationPrescribed   String?
  proceduresPerformed    String?
  testsRequested         String?
  laboratoryRequests     String?
  imagingRequests        String?
  referrals              String?
  followUpInstructions   String?
  followUpDate           DateTime?
  patientSummary         String?
  privateNotes           String?
  status                 String                @default("DRAFT")
  completedAt            DateTime?
  createdById            String
  updatedById            String
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  practice               Practice              @relation(fields: [practiceId], references: [id])
  patient                Patient               @relation(fields: [patientId], references: [id])
  appointment            Appointment?          @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  clinician              User                  @relation("EncounterClinician", fields: [clinicianId], references: [id])
  createdBy              User                  @relation("EncounterCreator", fields: [createdById], references: [id])
  updatedBy              User                  @relation("EncounterUpdater", fields: [updatedById], references: [id])
  diagnoses              EncounterDiagnosis[]
  amendments             EncounterAmendment[]
  attachments            EncounterAttachment[]

  @@unique([practiceId, appointmentId])
  @@index([practiceId, patientId, startedAt])
  @@index([practiceId, clinicianId, status])
}

model EncounterDiagnosis {
  id                   String            @id @default(cuid())
  encounterId          String
  code                 String?
  description          String
  clinicianDescription String?
  diagnosisType        String            @default("PROVISIONAL")
  isPrimary            Boolean           @default(false)
  summaryDisposition   String            @default("DO_NOT_ADD")
  createdAt            DateTime          @default(now())
  encounter            ClinicalEncounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([encounterId, isPrimary])
}

model EncounterAmendment {
  id              String            @id @default(cuid())
  encounterId     String
  amendedById     String
  reason          String
  originalContent Json
  updatedContent  Json
  createdAt       DateTime          @default(now())
  encounter       ClinicalEncounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  amendedBy       User              @relation(fields: [amendedById], references: [id])

  @@index([encounterId, createdAt])
}

model EncounterAttachment {
  id           String            @id @default(cuid())
  encounterId  String
  filename     String
  mimeType     String
  fileSize     Int
  data         Bytes
  uploadedById String
  createdAt    DateTime          @default(now())
  encounter    ClinicalEncounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([encounterId, createdAt])
}

model ProviderAvailability {
  id         String   @id @default(cuid())
  practiceId String
  providerId String
  weekday    Int
  active     Boolean  @default(true)
  openTime   String
  closeTime  String
  breakStart String?
  breakEnd   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, weekday])
  @@index([practiceId, weekday])
}

model SubscriptionPlan {
  id               String                 @id @default(cuid())
  name             String                 @unique
  description      String?
  billingFrequency String                 @default("MONTHLY")
  fee              Float                  @default(0)
  gracePeriodDays  Int                    @default(7)
  features         Json?
  active           Boolean                @default(true)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  subscriptions    PracticeSubscription[]
}

model PracticeSubscription {
  id            String                @id @default(cuid())
  practiceId    String
  planId        String
  status        String                @default("ACTIVE")
  startDate     DateTime              @default(now())
  renewalDate   DateTime?
  graceUntil    DateTime?
  cancelledAt   DateTime?
  internalNotes String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  practice      Practice              @relation(fields: [practiceId], references: [id])
  plan          SubscriptionPlan      @relation(fields: [planId], references: [id])
  payments      SubscriptionPayment[]

  @@index([practiceId, status])
}

model SubscriptionPayment {
  id             String               @id @default(cuid())
  subscriptionId String
  amount         Float
  paidAt         DateTime             @default(now())
  method         String?
  reference      String?
  notes          String?
  recordedById   String?
  subscription   PracticeSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, paidAt])
}

model UserInvitation {
  id          String    @id @default(cuid())
  practiceId  String
  email       String
  name        String
  role        String    @default("OWNER")
  tokenHash   String    @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  invitedById String
  createdAt   DateTime  @default(now())
  practice    Practice  @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([practiceId, email, acceptedAt])
}

model SupportAccessGrant {
  id          String    @id @default(cuid())
  practiceId  String
  patientId   String
  reason      String
  grantedToId String
  grantedById String
  expiresAt   DateTime
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([grantedToId, expiresAt, revokedAt])
  @@index([practiceId, patientId, expiresAt])
}

model PracticeApplication {
  id                 String    @id @default(cuid())
  practiceName       String
  practiceType       String
  ownerName          String
  email              String
  phone              String?
  registrationNumber String?
  town               String?
  region             String?
  description        String?
  status             String    @default("SUBMITTED")
  reviewNotes        String?
  reviewedById       String?
  reviewedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([email, createdAt])
}

model LoginThrottle {
  key             String    @id
  failures        Int       @default(0)
  windowStartedAt DateTime  @default(now())
  blockedUntil    DateTime?
  updatedAt       DateTime  @updatedAt

  @@index([updatedAt])
}
