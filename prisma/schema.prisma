generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String                     @id @default(cuid())
  name                 String
  email                String                     @unique
  passwordHash         String
  role                 String                     @default("RECEPTIONIST")
  permissions          String                     @default("[]")
  avatarData           String?
  active               Boolean                    @default(true)
  mustChangePassword   Boolean                    @default(false)
  sessionVersion       Int                        @default(0)
  updatedAt            DateTime                   @default(now()) @updatedAt
  createdAt            DateTime                   @default(now())
  appointments         Appointment[]              @relation("CreatedBy")
  payments             Payment[]
  logs                 ActivityLog[]
  appointmentResponses AppointmentChangeRequest[] @relation("ChangeResponder")
  icd10Imports         Icd10Import[]              @relation("Icd10Importer")
  consentsCaptured     MedicalAidConsent[]        @relation("ConsentCapturer")
  claimsCreated        Claim[]                    @relation("ClaimCreator")
  claimEvents          ClaimStatusEvent[]
  batchesSubmitted     ClaimBatch[]               @relation("BatchSubmitter")
  claimAttachments     ClaimAttachment[]
}

model Patient {
  id                String              @id @default(cuid())
  patientNumber     String              @unique
  fullName          String
  surname           String              @default("")
  initials          String              @default("")
  dateOfBirth       DateTime?
  gender            String?
  identityNumber    String?
  nationality       String?
  phone             String
  whatsapp          String?
  email             String?
  address           String?
  preferredMethod   String              @default("WHATSAPP")
  emergencyName     String?
  emergencyPhone    String?
  emergencyRelation String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  archivedAt        DateTime?
  appointments      Appointment[]
  memberships       PatientMedicalAid[]
  claims            Claim[]
  invoices          Invoice[]
  payments          Payment[]
  consents          MedicalAidConsent[]
}

model MedicalAid {
  id                        String              @id @default(cuid())
  name                      String              @unique
  normalizedName            String              @unique
  abbreviation              String?
  administrator             String?
  claimsEmail               String?
  supportEmail              String?
  phone                     String?
  portalUrl                 String?
  submissionInstructions    String?
  postalAddress             String?
  physicalAddress           String?
  acceptedSubmissionMethods String              @default("[]")
  coverSheetRequired        Boolean             @default(false)
  serviceDateRangeRequired  Boolean             @default(false)
  active                    Boolean             @default(true)
  public                    Boolean             @default(true)
  sortOrder                 Int                 @default(0)
  memberships               PatientMedicalAid[]
  claims                    Claim[]
  batches                   ClaimBatch[]
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @default(now()) @updatedAt
}

model PatientMedicalAid {
  id                     String              @id @default(cuid())
  patientId              String
  medicalAidId           String?
  customFundName         String?
  membershipNumber       String?
  plan                   String?
  principalName          String?
  principalId            String?
  dependantCode          String?
  relationship           String?
  beneficiarySuffix      String?
  effectiveDate          DateTime?
  expiryDate             DateTime?
  preAuthorisationNumber String?
  directBillingEnabled   Boolean             @default(true)
  reimbursementOnly      Boolean             @default(false)
  notes                  String?
  current                Boolean             @default(true)
  verified               Boolean             @default(false)
  patient                Patient             @relation(fields: [patientId], references: [id])
  medicalAid             MedicalAid?         @relation(fields: [medicalAidId], references: [id])
  consents               MedicalAidConsent[]
  claims                 Claim[]
  attachments            ClaimAttachment[]
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @default(now()) @updatedAt

  @@index([patientId, current])
}

model Appointment {
  id               String                     @id @default(cuid())
  reference        String                     @unique
  patientId        String
  startAt          DateTime?
  endAt            DateTime?
  preferredDate    DateTime?
  preferredPeriod  String?
  preferredTime    String?
  status           String                     @default("NEW_REQUEST")
  bookingMode      String                     @default("AVAILABLE_TIME")
  source           String                     @default("PUBLIC")
  reason           String
  notes            String?
  internalNote     String?
  originalStartAt  DateTime?
  rescheduleReason String?
  contacted        Boolean                    @default(false)
  createdById      String?
  patient          Patient                    @relation(fields: [patientId], references: [id])
  createdBy        User?                      @relation("CreatedBy", fields: [createdById], references: [id])
  claim            Claim?
  invoice          Invoice?
  secureLinks      SecureLink[]
  changeRequests   AppointmentChangeRequest[]
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  @@unique([startAt])
  @@index([status, startAt])
}

model AvailabilityRule {
  id              String  @id @default(cuid())
  weekday         Int     @unique
  active          Boolean @default(true)
  openTime        String
  closeTime       String
  lunchStart      String?
  lunchEnd        String?
  durationMinutes Int     @default(30)
  bufferMinutes   Int     @default(0)
  maximumPerDay   Int     @default(16)
}

model BlockedTime {
  id      String   @id @default(cuid())
  startAt DateTime
  endAt   DateTime
  reason  String?
}

model PracticeSetting {
  id                 String  @id @default("practice")
  practiceName       String  @default("Mondesa Health")
  doctorName         String  @default("Dr Helena Ndeitunga")
  practiceNumber     String  @default("Pending configuration")
  registrationNumber String  @default("Pending configuration")
  phone              String  @default("+264 81 000 0000")
  whatsapp           String  @default("+264 81 000 0000")
  email              String  @default("hello@mondesahealth.na")
  address            String  @default("Mondesa, Swakopmund, Namibia")
  bookingMode        String  @default("AVAILABLE_TIME")
  minNoticeHours     Int     @default(2)
  maxAdvanceDays     Int     @default(60)
  cancellationPolicy String  @default("Please give at least 4 hours' notice when possible.")
  currency           String  @default("NAD")
  signatureName      String  @default("Dr Helena Ndeitunga")
  signatureTitle     String  @default("Medical Practitioner")
  vatEnabled         Boolean @default(false)
  tagline            String  @default("Your Health. Your Choice. Your Community.")
  publicDescription  String  @default("Mondesa Health Polyclinic brings multiple healthcare disciplines together in one trusted community healthcare destination.")
  locationNote       String  @default("")
  mapsUrl            String  @default("")
  mapLatitude        Float?
  mapLongitude       Float?
  publicHours        String?
  showEmail          Boolean @default(false)
  showWhatsapp       Boolean @default(false)
  claimContactName   String  @default("")
  claimPhone         String  @default("")
  claimEmail         String  @default("")
  claimPostalAddress String  @default("")
  consentWording     String  @default("I understand that diagnosis information may be represented using ICD-10 codes and disclosed to the selected medical-aid fund or its administrator for the purpose of processing and assessing my medical-aid claim.")
}

model Department {
  id             String              @id @default(cuid())
  slug           String              @unique
  name           String
  categoryLabel  String
  summary        String
  description    String
  status         String              @default("COMING_SOON")
  public         Boolean             @default(true)
  bookingEnabled Boolean             @default(false)
  sortOrder      Int                 @default(0)
  services       DepartmentService[]
  providers      Provider[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([public, sortOrder])
  @@index([status])
}

model DepartmentService {
  id           String     @id @default(cuid())
  departmentId String
  name         String
  description  String?
  public       Boolean    @default(true)
  sortOrder    Int        @default(0)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([departmentId, name])
  @@index([departmentId, public, sortOrder])
}

model Provider {
  id             String     @id @default(cuid())
  departmentId   String
  displayName    String
  practiceName   String?
  biography      String?
  phone          String?
  email          String?
  operatingHours String?
  public         Boolean    @default(false)
  sortOrder      Int        @default(0)
  department     Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([departmentId, public, sortOrder])
}

model Claim {
  id                       String             @id @default(cuid())
  claimNumber              String             @unique
  patientId                String
  appointmentId            String?            @unique
  patientMedicalAidId      String?
  medicalAidFundId         String?
  createdByUserId          String?
  originalClaimId          String?
  status                   String             @default("DRAFT")
  claimType                String             @default("DIRECT_MEDICAL_AID")
  submissionType           String             @default("FIRST_SUBMISSION")
  isResubmission           Boolean            @default(false)
  serviceDateFrom          DateTime?
  serviceDateTo            DateTime?
  consultationDate         DateTime
  practitioner             String
  practiceNumber           String
  medicalAidSnapshot       String?
  membershipSnapshot       String?
  principalSnapshot        String?
  dependantSnapshot        String?
  planSnapshot             String?
  primaryDiagnosis         String?
  primaryIcd10             String?
  amountSubmitted          Float              @default(0)
  amountApproved           Float              @default(0)
  amountReceived           Float              @default(0)
  patientShortfall         Float              @default(0)
  patientSnapshot          String?
  membershipDetailSnapshot String?
  providerSnapshot         String?
  practiceSnapshot         String?
  consentSnapshot          String?
  validationState          String?
  internalNotes            String?
  submittedAt              DateTime?
  acknowledgedAt           DateTime?
  patient                  Patient            @relation(fields: [patientId], references: [id])
  appointment              Appointment?       @relation(fields: [appointmentId], references: [id])
  patientMedicalAid        PatientMedicalAid? @relation(fields: [patientMedicalAidId], references: [id])
  medicalAidFund           MedicalAid?        @relation(fields: [medicalAidFundId], references: [id])
  createdBy                User?              @relation("ClaimCreator", fields: [createdByUserId], references: [id])
  originalClaim            Claim?             @relation("ClaimResubmissions", fields: [originalClaimId], references: [id])
  resubmissions            Claim[]            @relation("ClaimResubmissions")
  lines                    ClaimLine[]
  batches                  ClaimBatchItem[]
  payments                 Payment[]
  statusEvents             ClaimStatusEvent[]
  attachments              ClaimAttachment[]
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  @@index([status, updatedAt])
  @@index([patientId, serviceDateFrom])
  @@index([medicalAidFundId, status])
}

model ClaimLine {
  id                           String                   @id @default(cuid())
  claimId                      String
  serviceDate                  DateTime?
  procedureItemId              String?
  procedureCodeSnapshot        String?
  procedureDescriptionSnapshot String?
  tariffCode                   String?
  description                  String
  icd10                        String?
  quantity                     Float                    @default(1)
  rate                         Float
  claimed                      Float
  approved                     Float                    @default(0)
  rejected                     Float                    @default(0)
  patientAmount                Float                    @default(0)
  modifier                     String?
  nappiCode                    String?
  medicationDescription        String?
  referralDiagnosis            String?
  preAuthorisationNumber       String?
  clinicalClaimNote            String?
  sortOrder                    Int                      @default(0)
  claim                        Claim                    @relation(fields: [claimId], references: [id], onDelete: Cascade)
  procedureItem                MedicalAidProcedureItem? @relation(fields: [procedureItemId], references: [id])
  diagnosisCodes               ClaimLineIcd10Code[]

  @@index([claimId, sortOrder])
}

model ClaimBatch {
  id                  String            @id @default(cuid())
  reference           String            @unique
  medicalAidName      String
  medicalAidFundId    String?
  submissionType      String            @default("FIRST_SUBMISSION")
  datePrepared        DateTime          @default(now())
  serviceDateFrom     DateTime?
  serviceDateTo       DateTime?
  totalClaims         Int               @default(0)
  periodStart         DateTime
  periodEnd           DateTime
  totalAmount         Float
  status              String            @default("DRAFT")
  submissionMethod    String?
  submittedAt         DateTime?
  submissionReference String?
  submittedByUserId   String?
  acknowledgedAt      DateTime?
  notes               String?
  medicalAidFund      MedicalAid?       @relation(fields: [medicalAidFundId], references: [id])
  submittedBy         User?             @relation("BatchSubmitter", fields: [submittedByUserId], references: [id])
  items               ClaimBatchItem[]
  attachments         ClaimAttachment[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @default(now()) @updatedAt

  @@index([medicalAidFundId, status])
}

model ClaimBatchItem {
  batchId String
  claimId String
  batch   ClaimBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  claim   Claim      @relation(fields: [claimId], references: [id])

  @@id([batchId, claimId])
}

model MedicalAidConsent {
  id                    String             @id @default(cuid())
  patientId             String
  patientMedicalAidId   String?
  consentStatus         String             @default("NOT_CAPTURED")
  consentDate           DateTime           @default(now())
  patientOrGuardianName String
  relationshipToPatient String?
  capturedByUserId      String
  signatureData         String?
  notes                 String?
  patient               Patient            @relation(fields: [patientId], references: [id])
  patientMedicalAid     PatientMedicalAid? @relation(fields: [patientMedicalAidId], references: [id])
  capturedBy            User               @relation("ConsentCapturer", fields: [capturedByUserId], references: [id])
  createdAt             DateTime           @default(now())

  @@index([patientId, consentDate])
}

model Icd10Import {
  id               String      @id @default(cuid())
  versionName      String      @unique
  sourceFilename   String
  importedAt       DateTime    @default(now())
  importedByUserId String?
  totalRows        Int         @default(0)
  importedRows     Int         @default(0)
  skippedRows      Int         @default(0)
  invalidRows      Int         @default(0)
  active           Boolean     @default(false)
  notes            String?
  importedBy       User?       @relation("Icd10Importer", fields: [importedByUserId], references: [id])
  codes            Icd10Code[]

  @@index([active, importedAt])
}

model Icd10Code {
  id                        String               @id @default(cuid())
  importId                  String
  code                      String
  description               String
  threeCharacterCode        String?
  threeCharacterDescription String?
  chapter                   String?
  chapterDescription        String?
  groupCode                 String?
  groupDescription          String?
  validForClinicalUse       Boolean              @default(false)
  validForPrimary           Boolean              @default(false)
  validAsterisk             Boolean              @default(false)
  validDagger               Boolean              @default(false)
  validSequelae             Boolean              @default(false)
  ageRange                  String?
  minimumAge                Int?
  maximumAge                Int?
  genderRestriction         String?
  status                    String?
  startDate                 DateTime?
  endDate                   DateTime?
  comment                   String?
  import                    Icd10Import          @relation(fields: [importId], references: [id], onDelete: Cascade)
  claimLines                ClaimLineIcd10Code[]
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt

  @@unique([importId, code])
  @@index([code])
  @@index([description])
  @@index([importId, validForClinicalUse, validForPrimary])
}

model MedicalAidProcedureItem {
  id                       String      @id @default(cuid())
  code                     String      @unique
  name                     String
  description              String?
  category                 String?
  defaultAmount            Float       @default(0)
  requiresNappiCode        Boolean     @default(false)
  requiresPreAuthorisation Boolean     @default(false)
  active                   Boolean     @default(true)
  claimLines               ClaimLine[]
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt
}

model ClaimLineIcd10Code {
  id                  String     @id @default(cuid())
  claimLineId         String
  icd10CodeId         String?
  codeSnapshot        String
  descriptionSnapshot String
  position            String     @default("SECONDARY")
  isPrimary           Boolean    @default(false)
  sortOrder           Int        @default(0)
  claimLine           ClaimLine  @relation(fields: [claimLineId], references: [id], onDelete: Cascade)
  icd10Code           Icd10Code? @relation(fields: [icd10CodeId], references: [id])
  createdAt           DateTime   @default(now())

  @@unique([claimLineId, codeSnapshot])
  @@index([claimLineId, isPrimary])
}

model ClaimStatusEvent {
  id                   String   @id @default(cuid())
  claimId              String
  previousStatus       String?
  newStatus            String
  reason               String?
  rejectionCode        String?
  rejectionDescription String?
  changedByUserId      String
  claim                Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)
  changedBy            User     @relation(fields: [changedByUserId], references: [id])
  createdAt            DateTime @default(now())

  @@index([claimId, createdAt])
}

model ClaimAttachment {
  id                  String             @id @default(cuid())
  claimId             String?
  batchId             String?
  patientMedicalAidId String?
  attachmentType      String
  filename            String
  mimeType            String
  fileSize            Int
  data                Bytes
  uploadedByUserId    String
  claim               Claim?             @relation(fields: [claimId], references: [id], onDelete: Cascade)
  batch               ClaimBatch?        @relation(fields: [batchId], references: [id], onDelete: Cascade)
  patientMedicalAid   PatientMedicalAid? @relation(fields: [patientMedicalAidId], references: [id], onDelete: Cascade)
  uploadedBy          User               @relation(fields: [uploadedByUserId], references: [id])
  createdAt           DateTime           @default(now())

  @@index([claimId, createdAt])
  @@index([batchId, createdAt])
}

model Invoice {
  id                       String              @id @default(cuid())
  number                   String              @unique
  patientId                String
  appointmentId            String?             @unique
  status                   String              @default("DRAFT")
  responsibility           String              @default("PATIENT_FULL")
  issueDate                DateTime            @default(now())
  dueDate                  DateTime?
  subtotal                 Float
  adjustment               Float               @default(0)
  total                    Float
  patientResponsibility    Float
  medicalAidResponsibility Float               @default(0)
  patientPaid              Float               @default(0)
  medicalAidPaid           Float               @default(0)
  patient                  Patient             @relation(fields: [patientId], references: [id])
  appointment              Appointment?        @relation(fields: [appointmentId], references: [id])
  lines                    InvoiceLine[]
  payments                 Payment[]
  documents                GeneratedDocument[]
  createdAt                DateTime            @default(now())
}

model InvoiceLine {
  id                String  @id @default(cuid())
  invoiceId         String
  description       String
  tariffCode        String?
  quantity          Float   @default(1)
  rate              Float
  total             Float
  patientPortion    Float
  medicalAidPortion Float   @default(0)
  invoice           Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Payment {
  id        String   @id @default(cuid())
  reference String   @unique
  patientId String
  invoiceId String?
  claimId   String?
  userId    String
  amount    Float
  method    String
  payer     String
  paidAt    DateTime @default(now())
  notes     String?
  patient   Patient  @relation(fields: [patientId], references: [id])
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])
  claim     Claim?   @relation(fields: [claimId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  receipt   Receipt?
}

model Receipt {
  id        String   @id @default(cuid())
  number    String   @unique
  paymentId String   @unique
  payment   Payment  @relation(fields: [paymentId], references: [id])
  issuedAt  DateTime @default(now())
}

model GeneratedDocument {
  id          String    @id @default(cuid())
  number      String    @unique
  type        String
  status      String    @default("ISSUED")
  invoiceId   String?
  secureToken String?   @unique
  expiresAt   DateTime?
  invoice     Invoice?  @relation(fields: [invoiceId], references: [id])
  createdAt   DateTime  @default(now())
}

model SecureLink {
  id            String      @id @default(cuid())
  tokenHash     String      @unique
  appointmentId String
  purpose       String
  expiresAt     DateTime
  usedAt        DateTime?
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  createdAt     DateTime    @default(now())
}

model AppointmentChangeRequest {
  id              String      @id @default(cuid())
  appointmentId   String
  proposedStartAt DateTime
  proposedEndAt   DateTime
  initiatedBy     String
  status          String      @default("PENDING")
  reason          String?
  expiresAt       DateTime
  respondedAt     DateTime?
  respondedById   String?
  appointment     Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  respondedBy     User?       @relation("ChangeResponder", fields: [respondedById], references: [id])
  createdAt       DateTime    @default(now())

  @@index([status, proposedStartAt, expiresAt])
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String
  summary    String
  beforeJson String?
  afterJson  String?
  user       User?    @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
}

model LoginThrottle {
  key             String    @id
  failures        Int       @default(0)
  windowStartedAt DateTime  @default(now())
  blockedUntil    DateTime?
  updatedAt       DateTime  @updatedAt

  @@index([updatedAt])
}
