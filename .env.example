# Pooled Neon connection used by the application at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@ep-example-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Direct Neon connection used by Prisma schema and migration commands.
DIRECT_URL="postgresql://USER:PASSWORD@ep-example.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

AUTH_SECRET="replace-with-at-least-32-random-characters"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
ATTACHMENT_STORAGE_LIMIT_MB="1024"

# Optional outbound invitation email. Invitations are never emailed unless an
# operator explicitly selects the email option during registration/approval.
RESEND_API_KEY=""
INVITATION_EMAIL_FROM="Mondesa Health <invitations@example.com>"

# Optional server-only OpenAI integration. The model defaults to gpt-4o-mini.
OPENAI_API_KEY="store-only-in-the-approved-deployment-secret-manager"
OPENAI_MODEL="gpt-4o-mini"

# Used by encrypted logical backups. Store this separately from the backup files.
BACKUP_ENCRYPTION_KEY="replace-with-at-least-32-random-characters"
BACKUP_DIR="/secure/path/to/mondesahealth-backups"

# Restore drills only: must be a disposable database, never the live database.
RESTORE_DATABASE_URL="postgresql://USER:PASSWORD@disposable-host.example/neondb?sslmode=require"

# Used only by `pnpm db:seed` to create the first owner account.
OWNER_NAME="Practice Owner"
OWNER_EMAIL="owner@mondesahealth.na"
OWNER_PASSWORD="replace-with-a-strong-temporary-password"
